generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  password  String
  role      String   @default("DRIVER")
  points    Int      @default(0)
  active    Boolean  @default(true)
  approved  Boolean  @default(false)
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shops               Shop[]
  deliveryOffers      DeliveryOffer[]
  pointsTransactions  PointsTransaction[]
  ordersCreated       Order[]              @relation("OrderCreator")
  ordersAccepted      Order[]              @relation("AcceptedDriver")
  paymentRequests     PaymentRequest[]
  notifications       Notification[]

  @@map("users")
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("OTHER")
  address   String
  phone     String
  active    Boolean  @default(true)
  ownerId   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User      @relation(fields: [ownerId], references: [id])
  orders  Order[]
  earnings Earning[]

  @@map("shops")
}

model Order {
  id                String   @id @default(cuid())
  shopId            String
  description       String
  pickupAddress     String
  deliveryAddress   String
  status            String   @default("PENDING")
  deliveryFee       Float    @default(0)
  commission        Float    @default(0)
  pointsCost        Int      @default(1)
  createdById       String
  acceptedDriverId  String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  shop            Shop             @relation(fields: [shopId], references: [id])
  createdBy       User             @relation("OrderCreator", fields: [createdById], references: [id])
  acceptedDriver  User?            @relation("AcceptedDriver", fields: [acceptedDriverId], references: [id])
  offers          DeliveryOffer[]
  earning         Earning?

  @@map("orders")
}

model Earning {
  id            String   @id @default(cuid())
  orderId       String   @unique
  shopId        String
  deliveryFee   Float
  commission    Float
  driverEarning Float
  createdAt     DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])

  @@map("earnings")
}

model DeliveryOffer {
  id        String   @id @default(cuid())
  orderId   String
  driverId  String
  price     Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order  Order @relation(fields: [orderId], references: [id])
  driver User  @relation(fields: [driverId], references: [id])

  @@map("delivery_offers")
}

model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("points_transactions")
}

model PaymentRequest {
  id              String    @id @default(cuid())
  userId          String
  amount          Int
  paymentMethod   String
  senderPhone     String
  senderName      String
  receiptNumber   String?
  status          String    @default("PENDING")
  adminNote       String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("payment_requests")
}

model PaymentMethodSetting {
  id            String   @id
  name          String
  icon          String   @default("📱")
  color         String   @default("from-red-500 to-red-600")
  accountName   String   @default("المدير")
  accountPhone  String   @default("01000000000")
  instructions  String   @default("")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("payment_method_settings")
}

model AppSetting {
  id         String   @id
  pointPrice Float    @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  relatedId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
